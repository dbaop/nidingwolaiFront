/* detail.wxss */
.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding: 20rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 32rpx;
  color: #999;
}

.activity-detail {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.activity-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  line-height: 1.4;
}

.activity-info {
  margin-bottom: 40rpx;
}

.info-item {
  display: flex;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.info-label {
  color: #666;
  width: 160rpx;
}

.info-value {
  color: #333;
  flex: 1;
  word-break: break-word;
}

.activity-description, .activity-rules {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.description-content, .rules-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-word;
}

.activity-image {
  margin-bottom: 40rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.activity-image image {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
}

.action-buttons {
  margin-bottom: 30rpx;
}

.status-button {
  width: 100%;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.pending {
  color: #ff9800;
}

.review-section {
  margin-top: 40rpx;
}

.reviews-list {
  margin-bottom: 30rpx;
}

.review-item {
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.reviewer-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.review-date {
  font-size: 24rpx;
  color: #999;
}

.review-content {
  font-size: 26rpx;
  color: #666;
}

.review-rating {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.review-rating .stars {
  margin-right: 16rpx;
}

.review-rating .star {
  font-size: 28rpx;
  margin-right: 8rpx;
  color: #FFD700;
  font-weight: bold;
}

.rating-type {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-left: 8rpx;
}

.rating-type-good {
  background-color: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.rating-type-bad {
  background-color: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.rating-type-neutral {
  background-color: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}

.review-comment {
  margin-top: 12rpx;
  line-height: 1.5;
  word-break: break-all;
}

.empty-reviews {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
}

.review-form {
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.rating-input {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.stars {
  display: flex;
}

.star {
  font-size: 40rpx;
  margin-right: 20rpx;
  cursor: pointer;
}

.comment-input {
  margin-bottom: 30rpx;
}

.comment-input textarea {
  width: 100%;
  height: 120rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.submit-review-btn {
  width: 100%;
  height: 80rpx;
  background-color: #FF6B8B;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

.approved {
  color: #4caf50;
}

.rejected {
  color: #f44336;
}

.attended {
  color: #2196f3;
}

.canceled {
  color: #9e9e9e;
}

button {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  border-radius: 40rpx;
  margin: 0;
}

.back-button button {
  background-color: #e0e0e0;
  color: #333;
}
