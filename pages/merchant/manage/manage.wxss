/* merchant/manage/manage.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin: 30rpx 0;
  color: #333;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
}

.empty-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
  font-size: 28rpx;
}

/* 商家申请列表样式 */
.application-list {
  width: 100%;
}

.application-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.app-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.app-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.app-info {
  display: flex;
  flex-direction: column;
}

.app-nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.app-phone {
  font-size: 24rpx;
  color: #666;
}

.app-details {
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-row {
  display: flex;
  margin-bottom: 10rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  width: 140rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
}

.app-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  gap: 20rpx;
}

.btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  margin: 0;
}

.btn::after {
  border: none;
}

.approve-btn {
  background-color: #07c160;
  color: #fff;
}

.reject-btn {
  background-color: #fff;
  color: #999;
  border: 1rpx solid #ddd;
}

/* 商家信息卡片样式 */
.merchant-info-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.merchant-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.merchant-basic {
  display: flex;
  flex-direction: column;
}

.merchant-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.merchant-status {
  display: flex;
}

.status-badge {
  background-color: #e6f7ed;
  color: #07c160;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.info-body {
  padding-top: 10rpx;
}

.info-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}