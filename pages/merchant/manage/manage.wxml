<view class="container">
  <view class="title">{{userRole === 'admin' ? '商家申请管理' : '商家信息'}}</view>

  <!-- 加载状态 -->
  <view wx:if="{{isLoading}}" class="loading-container">
    <text>加载中...</text>
  </view>

  <!-- 管理员视图：商家申请列表 -->
  <view wx:if="{{userRole === 'admin'}}" class="content">
    <view wx:if="{{applications.length === 0}}" class="empty-tip">
      <text>暂无待审核的商家申请</text>
    </view>

    <view wx:else class="application-list">
      <view wx:for="{{applications}}" wx:key="id" class="application-item">
        <view class="app-header">
          <image class="app-avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="app-info">
            <text class="app-nickname">{{item.nickname}}</text>
            <text class="app-phone">{{item.phone || '未填写手机号'}}</text>
          </view>
        </view>

        <view class="app-details">
          <view class="detail-row">
            <text class="detail-label">申请时间：</text>
            <text class="detail-value">{{item.updated_at}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">信用分：</text>
            <text class="detail-value">{{item.credit_score}}</text>
          </view>
        </view>

        <view class="app-actions">
          <button class="btn approve-btn" data-userid="{{item.id}}" data-action="approve" bindtap="reviewApplication">
            通过
          </button>
          <button class="btn reject-btn" data-userid="{{item.id}}" data-action="reject" bindtap="reviewApplication">
            拒绝
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 商家视图：商家信息 -->
  <view wx:if="{{userRole === 'merchant'}}" class="content">
    <view wx:if="{{merchantInfo}}" class="merchant-info-card">
      <view class="info-header">
        <image class="merchant-avatar" src="{{merchantInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="merchant-basic">
          <text class="merchant-name">{{merchantInfo.nickname}}</text>
          <view class="merchant-status">
            <text class="status-badge">已认证商家</text>
          </view>
        </view>
      </view>

      <view class="info-body">
        <view class="info-row">
          <text class="info-label">手机号</text>
          <text class="info-value">{{merchantInfo.phone || '未填写'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">信用分</text>
          <text class="info-value">{{merchantInfo.credit_score}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">简介</text>
          <text class="info-value">{{merchantInfo.bio || '暂无简介'}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!merchantInfo}}" class="empty-tip">
      <text>加载商家信息中...</text>
    </view>
  </view>
</view>