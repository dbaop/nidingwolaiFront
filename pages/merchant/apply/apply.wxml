<view class="container">
  <view class="title">申请成为商家</view>
  <form class="form" bindsubmit="onSubmit">
    <view class="form-item">
      <text class="label">商家名称</text>
      <input name="business_name" placeholder="请输入商家名称" value="{{formData.business_name}}" bindinput="onInputChange" placeholder-class="placeholder"/>
    </view>
    <view class="form-item">
      <text class="label">联系人</text>
      <input name="contact_name" placeholder="请输入联系人姓名" value="{{formData.contact_name}}" bindinput="onInputChange" placeholder-class="placeholder"/>
    </view>
    <view class="form-item">
      <text class="label">联系电话</text>
      <input name="contact_phone" placeholder="请输入联系电话" value="{{formData.contact_phone}}" bindinput="onInputChange" type="number" placeholder-class="placeholder"/>
    </view>
    <view class="form-item">
      <text class="label">商家地址</text>
      <input name="address" placeholder="请输入商家地址" value="{{formData.address}}" bindinput="onInputChange" placeholder-class="placeholder"/>
    </view>
    <view class="form-item">
      <text class="label">商家简介</text>
      <textarea name="description" placeholder="请输入商家简介" value="{{formData.description}}" bindinput="onInputChange" placeholder-class="placeholder" auto-height/>
    </view>
    <view class="form-item">
      <text class="label">资质证明</text>
      <view class="upload-container">
        <view wx:if="{{formData.license_image}}" class="uploaded-image-wrapper">
          <image src="{{formData.license_image}}" mode="aspectFit" class="uploaded-image"/>
          <view class="remove-image" bindtap="removeImage">×</view>
        </view>
        <button wx:else class="upload-btn" bindtap="uploadImage">
          <view class="upload-icon-wrapper">
            <text class="upload-icon-text">+</text>
          </view>
          <text class="upload-text">上传资质证明</text>
        </button>
      </view>
    </view>
    <button class="submit-btn" type="primary" form-type="submit">提交申请</button>
  </form>
</view>