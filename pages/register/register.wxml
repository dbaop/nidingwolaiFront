<!-- register.wxml - 注册页面 -->
<view class="register-container">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle circle-1"></view>
    <view class="bg-circle circle-2"></view>
    <view class="bg-circle circle-3"></view>
  </view>

  <!-- 标题区域 -->
  <view class="register-header">
    <view class="header-icon">
      <text class="header-emoji">🎉</text>
    </view>
    <text class="header-title">欢迎加入</text>
    <text class="header-subtitle">你定我来</text>
  </view>

  <!-- 注册表单 -->
  <view class="register-form">
    <!-- 手机号 -->
    <view class="input-group">
      <view class="input-icon-wrapper">
        <text class="input-icon">📱</text>
      </view>
      <input
        class="input-field"
        type="number"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        maxlength="11"
      />
      <view class="input-clear" wx:if="{{phone}}" bindtap="clearPhone">
        <text class="clear-icon">×</text>
      </view>
    </view>

    <!-- 验证码 -->
    <view class="input-group verify-code-group">
      <view class="input-icon-wrapper">
        <text class="input-icon">🔐</text>
      </view>
      <input
        class="input-field verify-code-input"
        type="number"
        placeholder="请输入验证码"
        placeholder-class="input-placeholder"
        value="{{verifyCode}}"
        bindinput="onVerifyCodeInput"
        maxlength="6"
      />
      <view class="input-clear" wx:if="{{verifyCode}}" bindtap="clearVerifyCode">
        <text class="clear-icon">×</text>
      </view>
      <view class="send-code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendVerifyCode">
        <text class="send-code-text">{{sendBtnText}}</text>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="input-group">
      <view class="input-icon-wrapper">
        <text class="input-icon">👤</text>
      </view>
      <input
        class="input-field"
        placeholder="请输入昵称"
        placeholder-class="input-placeholder"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
      <view class="input-clear" wx:if="{{nickname}}" bindtap="clearNickname">
        <text class="clear-icon">×</text>
      </view>
    </view>

    <!-- 密码 -->
    <view class="input-group">
      <view class="input-icon-wrapper">
        <text class="input-icon">🔒</text>
      </view>
      <input
        class="input-field {{showPassword ? '' : 'password-field'}}"
        type="{{showPassword ? 'text' : 'password'}}"
        placeholder="请输入密码（至少6位）"
        placeholder-class="input-placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
        maxlength="20"
      />
      <view class="password-toggle" bindtap="togglePasswordVisibility">
        <text class="eye-icon">{{showPassword ? '🙈' : '👁️'}}</text>
      </view>
    </view>

    <!-- 确认密码 -->
    <view class="input-group">
      <view class="input-icon-wrapper">
        <text class="input-icon">🔐</text>
      </view>
      <input
        class="input-field {{showConfirmPassword ? '' : 'password-field'}}"
        type="{{showConfirmPassword ? 'text' : 'password'}}"
        placeholder="请再次输入密码"
        placeholder-class="input-placeholder"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
        maxlength="20"
      />
      <view class="password-toggle" bindtap="toggleConfirmPasswordVisibility">
        <text class="eye-icon">{{showConfirmPassword ? '🙈' : '👁️'}}</text>
      </view>
    </view>

    <!-- 密码匹配提示 -->
    <view class="password-hint" wx:if="{{confirmPassword && password !== confirmPassword}}">
      <text class="hint-icon">⚠️</text>
      <text class="hint-text">两次密码输入不一致</text>
    </view>

    <!-- 注册按钮 -->
    <button
      class="register-btn {{canRegister ? 'active' : ''}}"
      disabled="{{!canRegister || loading}}"
      bindtap="register"
    >
      <view wx:if="{{loading}}" class="loading-spinner"></view>
      {{loading ? '注册中...' : '立即注册'}}
    </button>

    <!-- 登录链接 -->
    <view class="login-link">
      <text class="link-text">已有账号？</text>
      <text class="link-btn" bindtap="goToLogin">立即登录</text>
    </view>
  </view>

  <!-- 底部协议 -->
  <view class="register-footer">
    <text class="footer-text">注册即表示同意</text>
    <text class="footer-link">《用户协议》</text>
    <text class="footer-text">和</text>
    <text class="footer-link">《隐私政策》</text>
  </view>
</view>
