/* reviews.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  background-color: white;
  padding: 36rpx 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  display: block;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 32rpx;
  color: #999;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 20rpx;
  background-color: white;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 20rpx;
  background-color: white;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-tip {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

.retry-btn {
  margin-top: 30rpx;
  width: 200rpx;
  height: 68rpx;
  font-size: 28rpx;
  background-color: #FF6B8B;
  color: white;
  border-radius: 34rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
}

.reviews-list {
  padding: 20rpx;
}

.review-item {
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.review-item:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.review-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fafafa;
}

.activity-title-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 8rpx;
  font-weight: 500;
}

.review-activity {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B8B;
  margin-bottom: 12rpx;
  display: inline-block;
  line-height: 1.4;
  text-decoration: underline;
  cursor: pointer;
  transition: color 0.2s ease;
}

.review-activity:active {
  color: #FF4400;
}

.activity-organizer {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.review-date {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.review-content {
  padding: 32rpx;
}

.review-rating {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.rating-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 16rpx;
  font-weight: 500;
}

.stars {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.star {
  font-size: 36rpx;
  margin-right: 8rpx;
  color: #FFD700;
  font-weight: bold;
}

.rating-type {
  font-size: 28rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
}

.review-comment {
  margin-bottom: 12rpx;
  background-color: #fafafa;
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #FF6B8B;
}

.comment-label {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
}

/* 评分类型样式 */
.rating-type-good {
  background-color: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.rating-type-bad {
  background-color: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.rating-type-neutral {
  background-color: #fff7e6;
  color: #fa8c16;
  border: 1rpx solid #ffd591;
}