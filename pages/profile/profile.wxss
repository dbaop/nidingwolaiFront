/* profile.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

/* 用户信息卡片 - 已登录 */
.user-card {
  background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 139, 0.3);
  margin-bottom: 24rpx;
  position: relative;
}

/* 卡片背景装饰 */
.user-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.user-bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.bg-1 {
  width: 200rpx;
  height: 200rpx;
  top: -80rpx;
  right: -40rpx;
}

.bg-2 {
  width: 120rpx;
  height: 120rpx;
  top: 100rpx;
  left: -30rpx;
}

.bg-3 {
  width: 80rpx;
  height: 80rpx;
  bottom: 60rpx;
  right: 80rpx;
}

/* 用户卡片内容 */
.user-card-content {
  position: relative;
  z-index: 1;
  padding: 40rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.avatar-wrapper {
  position: relative;
  width: 140rpx;
  height: 140rpx;
}

.avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 5rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9500 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.badge-edit {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
}

.avatar-emoji-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.95);
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4E8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.avatar-emoji {
  font-size: 70rpx;
  line-height: 1;
}

/* 用户主要信息 */
.user-main-info {
  text-align: center;
  margin-bottom: 30rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.user-role-tag {
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
}

.role-text {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 500;
}

.user-bio {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 统计数据 */
.user-stats-card {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 28rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.stat-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FF6B8B;
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888888;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f0f0;
}

/* ========== 未登录状态 - 新设计 ========== */
.login-card {
  background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 139, 0.35);
  margin-bottom: 24rpx;
  position: relative;
}

/* 背景装饰 */
.login-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  overflow: hidden;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.bg-circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: -80rpx;
  right: -40rpx;
  animation: float 6s ease-in-out infinite;
}

.bg-circle-2 {
  width: 150rpx;
  height: 150rpx;
  top: 60rpx;
  left: -50rpx;
  animation: float 8s ease-in-out infinite reverse;
}

.bg-circle-3 {
  width: 100rpx;
  height: 100rpx;
  top: 150rpx;
  right: 80rpx;
  animation: float 10s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0rpx); }
  50% { transform: translateY(-15rpx); }
}

/* 头像区域 */
.login-avatar-section {
  position: relative;
  display: flex;
  justify-content: center;
  padding-top: 50rpx;
  z-index: 1;
}

.login-avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.login-avatar-emoji {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.95);
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4E8 100%);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-emoji-text {
  font-size: 80rpx;
  line-height: 1;
}

.login-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.95);
  background-color: #ffffff;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.2);
}

.login-avatar-badge {
  position: absolute;
  bottom: 5rpx;
  right: 5rpx;
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9500 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.badge-icon {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 欢迎文字 */
.login-welcome {
  text-align: center;
  padding: 30rpx 40rpx 20rpx;
  position: relative;
  z-index: 1;
}

.login-welcome-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

.login-welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 功能介绍区域 */
.login-card-body {
  padding: 30rpx 36rpx 40rpx;
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
  z-index: 2;
  margin-top: 20rpx;
}

.login-features {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 16rpx;
}

.feature-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFF0F5 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.feature-icon {
  font-size: 40rpx;
}

.feature-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #999999;
}

.login-main-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 139, 0.35);
  margin-bottom: 24rpx;
}

.login-main-btn:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 139, 0.45);
}

.login-main-btn::after {
  border: none;
}

.login-tips {
  text-align: center;
}

.login-tip-text {
  font-size: 22rpx;
  color: #999999;
}

/* 功能菜单 */
.menu-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 36rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 30rpx;
  transition: background-color 0.2s ease;
}

.menu-item:active {
  background-color: #fafafa;
}

.menu-item.review-item {
  background-color: #fff8f7;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-text {
  width: 56rpx;
  font-size: 40rpx;
  margin-right: 24rpx;
  text-align: center;
  flex-shrink: 0;
}

.menu-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.menu-icon image {
  width: 100%;
  height: 100%;
}

.menu-text {
  flex: 1;
  color: #333333;
  font-size: 30rpx;
}

.menu-arrow-text {
  font-size: 40rpx;
  color: #cccccc;
  font-weight: 300;
  margin-left: 16rpx;
}

.menu-arrow {
  width: 28rpx;
  height: 28rpx;
  margin-left: 20rpx;
  opacity: 0.4;
}

/* 退出登录按钮 */
.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 24rpx;
  background-color: #ffffff;
  color: #FF6B8B;
  border: 2rpx solid #FF6B8B;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 15rpx rgba(255, 107, 139, 0.1);
}

.logout-btn:active {
  background-color: #fff5f7;
  transform: scale(0.98);
}

.logout-btn::after {
  border: none;
}