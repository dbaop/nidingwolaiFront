<!-- profile.wxml -->
<view class="container">
  <!-- 用户信息卡片 - 已登录 -->
  <view wx:if="{{isLogin}}" class="user-card logged-in">
    <!-- 渐变背景 -->
    <view class="user-card-bg">
      <view class="user-bg-circle bg-1"></view>
      <view class="user-bg-circle bg-2"></view>
      <view class="user-bg-circle bg-3"></view>
    </view>

    <!-- 用户信息主体 -->
    <view class="user-card-content">
      <!-- 头像（点击编辑） -->
      <view class="avatar-section" bindtap="editProfile">
        <view wx:if="{{userInfo.avatar}}" class="avatar-wrapper">
          <image
            class="avatar-img"
            src="{{userInfo.avatar}}"
            mode="aspectFill"
          ></image>
          <view class="avatar-edit-badge">
            <text class="badge-edit">✎</text>
          </view>
        </view>
        <view wx:else class="avatar-emoji-wrapper">
          <text class="avatar-emoji">👤</text>
        </view>
      </view>

      <!-- 用户名和角色 -->
      <view class="user-main-info">
        <view class="user-name-row">
          <text class="user-name">{{userInfo.nickname || '用户'}}</text>
          <view class="user-role-tag" wx:if="{{userRole !== 'user'}}">
            <text class="role-text">{{userRole === 'merchant' ? '商家' : '管理员'}}</text>
          </view>
        </view>
        <text class="user-bio">{{userInfo.bio || '这个人很懒，什么都没写'}}</text>
      </view>

      <!-- 统计数据 -->
      <view class="user-stats-card">
        <view class="stat-block">
          <text class="stat-num">{{userStats.joined}}</text>
          <text class="stat-label">已参加</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-block">
          <text class="stat-num">{{userStats.created}}</text>
          <text class="stat-label">已创建</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-block">
          <text class="stat-num">{{userInfo.credit_score || 100}}</text>
          <text class="stat-label">信用分</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 未登录状态 - 全新设计 -->
  <view wx:else class="login-card">
    <!-- 顶部渐变背景 -->
    <view class="login-card-bg">
      <view class="bg-circle bg-circle-1"></view>
      <view class="bg-circle bg-circle-2"></view>
      <view class="bg-circle bg-circle-3"></view>
    </view>

    <!-- 头像区域 -->
    <view class="login-avatar-section">
      <view class="login-avatar-wrapper">
        <view class="login-avatar-emoji">
          <text class="avatar-emoji-text">🎉</text>
        </view>
        <view class="login-avatar-badge">
          <text class="badge-icon">?</text>
        </view>
      </view>
    </view>

    <!-- 欢迎文字 -->
    <view class="login-welcome">
      <text class="login-welcome-title">hi, 你好!</text>
      <text class="login-welcome-subtitle">登录后开启你的社交之旅</text>
    </view>

    <!-- 功能介绍 -->
    <view class="login-card-body">
      <view class="login-features">
        <view class="feature-item">
          <view class="feature-icon-wrapper">
            <text class="feature-icon">🎤</text>
          </view>
          <view class="feature-text-wrap">
            <text class="feature-title">发现活动</text>
            <text class="feature-desc">附近有趣的社交活动</text>
          </view>
        </view>
        <view class="feature-item">
          <view class="feature-icon-wrapper">
            <text class="feature-icon">👥</text>
          </view>
          <view class="feature-text-wrap">
            <text class="feature-title">结识伙伴</text>
            <text class="feature-desc">和志同道合的人交朋友</text>
          </view>
        </view>
        <view class="feature-item">
          <view class="feature-icon-wrapper">
            <text class="feature-icon">🎉</text>
          </view>
          <view class="feature-text-wrap">
            <text class="feature-title">创建活动</text>
            <text class="feature-desc">发起属于你的专属活动</text>
          </view>
        </view>
      </view>

      <button class="login-main-btn" bindtap="goToLogin">
        <text class="login-btn-text">立即登录 / 注册</text>
      </button>

      <view class="login-tips">
        <text class="login-tip-text">登录即表示同意《用户协议》和《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view wx:if="{{isLogin}}" class="menu-section">
    <view class="menu-item" bindtap="goToMyActivities">
      <view class="menu-icon-text">📋</view>
      <text class="menu-text">我的活动</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-icon-text">⭐</view>
      <text class="menu-text">收藏</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <view class="menu-item review-item" bindtap="goToReviews">
      <view class="menu-icon-text">⭐</view>
      <text class="menu-text">评价</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <view class="menu-item" bindtap="goToWallet">
      <view class="menu-icon-text">💰</view>
      <text class="menu-text">钱包</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <!-- 申请商家按钮，仅普通用户可见 -->
    <view wx:if="{{userRole === 'user'}}" class="menu-item" bindtap="applyForMerchant">
      <view class="menu-icon-text">🏪</view>
      <text class="menu-text">申请商家</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <!-- 商家管理按钮，商家和管理员可见 -->
    <view wx:if="{{userRole === 'merchant' || userRole === 'admin'}}" class="menu-item" bindtap="goToMerchantManage">
      <view class="menu-icon-text">🏪</view>
      <text class="menu-text">商家管理</text>
      <text class="menu-arrow-text">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-icon-text">⚙️</view>
      <text class="menu-text">设置</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <view class="menu-item" bindtap="goToHelp">
      <view class="menu-icon-text">❓</view>
      <text class="menu-text">帮助中心</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <view class="menu-item" bindtap="goToFeedback">
      <view class="menu-icon-text">💬</view>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow-text">›</text>
    </view>
    <view class="menu-item" bindtap="aboutUs">
      <view class="menu-icon-text">ℹ️</view>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow-text">›</text>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <button wx:if="{{isLogin}}" class="logout-btn" type="default" bindtap="logout">
    退出登录
  </button>
</view>