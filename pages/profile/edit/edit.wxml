<!-- edit.wxml -->
<view class="container">
  <!-- 头像部分 -->
  <view class="avatar-section">
    <view class="avatar-container" bindtap="chooseAvatar">
      <image class="avatar" src="{{userInfo.avatar || '/images/avatar.png'}}"></image>
      <view class="avatar-edit">
        <image src="/images/edit.png"></image>
        <text>点击更换</text>
      </view>
    </view>
  </view>

  <!-- 表单部分 -->
  <view class="form-section">
    <!-- 昵称 -->
    <view class="form-item">
      <view class="form-label">昵称</view>
      <input class="form-input" placeholder="请输入昵称" value="{{userInfo.nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <view class="form-label">性别</view>
      <radio-group class="radio-group" bindchange="onGenderChange">
        <label class="radio-item">
          <radio value="1" checked="{{userInfo.gender === 1}}" />
          <text>男</text>
        </label>
        <label class="radio-item">
          <radio value="2" checked="{{userInfo.gender === 2}}" />
          <text>女</text>
        </label>
      </radio-group>
    </view>

    <!-- 手机号（不可修改） -->
    <view class="form-item">
      <view class="form-label">手机号</view>
      <input class="form-input" value="{{userInfo.phone}}" disabled />
    </view>

    <!-- 演唱风格 -->
    <view class="form-item">
      <view class="form-label">演唱风格</view>
      <input class="form-input" placeholder="如：流行、摇滚、抒情" value="{{userInfo.singing_style}}" bindinput="onSingingStyleInput" maxlength="50" />
    </view>

    <!-- 个人简介 -->
    <view class="form-item">
      <view class="form-label">个人简介</view>
      <textarea class="form-textarea" placeholder="介绍一下自己吧" value="{{userInfo.bio}}" bindinput="onBioInput" maxlength="200" />
      <view class="char-count">{{userInfo.bio.length || 0}}/200</view>
    </view>
  </view>

  <!-- 按钮部分 -->
  <view class="button-section">
    <button class="reset-btn" bindtap="resetForm">重置</button>
    <button class="save-btn {{hasChanges ? 'active' : ''}}" bindtap="saveProfile" loading="{{loading}}" disabled="{{!hasChanges || loading}}">
      保存
    </button>
  </view>
</view>
