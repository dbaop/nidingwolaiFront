/* 创建活动页样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 表单部分 */
.form-section {
  margin-bottom: 24rpx;
  background-color: #ffffff;
  padding: 30rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: block;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B8B;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #666666;
  background-color: #f8f8f8;
  border-radius: 50rpx;
  border: 2rpx solid #e8e8e8;
  transition: all 0.2s ease;
}

.radio-item radio {
  margin-right: 10rpx;
  transform: scale(0.9);
}

.radio-item text {
  vertical-align: middle;
}

.radio-item[checked] {
  background-color: #fff5f7;
  border-color: #FF6B8B;
  color: #FF6B8B;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #FF6B8B;
  background-color: #ffffff;
  box-shadow: 0 0 0 6rpx rgba(255, 107, 139, 0.1);
}

/* 选择器 */
.picker {
  width: 100%;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 10rpx;
}

.picker-display {
  width: 100%;
  height: 80rpx;
  background-color: #ffffff;
  border: 2rpx solid #FF6B8B;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

/* 时间选择器样式 */
.time-picker-container {
  margin-bottom: 30rpx;
}

.time-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 15rpx;
}

.time-picker-row {
  display: flex;
  gap: 0;
  border: 2rpx solid #FF6B8B;
  border-radius: 12rpx;
  overflow: hidden;
}

.time-picker-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  font-size: 36rpx;
  background-color: #FF6B8B;
  color: #ffffff;
  border-radius: 12rpx 0 0 12rpx;
}

.time-picker-row picker {
  flex: 1;
}

.time-picker-row picker:last-child .time-picker-display {
  border-radius: 0 12rpx 12rpx 0;
}

.time-picker-display {
  width: 100%;
  min-height: 80rpx;
  background-color: #ffffff;
  color: #333333;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  border: none;
}

.time-picker-display:active {
  background-color: #fff5f5;
}

/* 时间输入框样式 */
.time-input-wrapper {
  position: relative;
  width: 100%;
  height: 80rpx;
}

.time-input {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  cursor: pointer;
  z-index: 1;
}

.time-input-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #999999;
  background-color: #ffffff;
  border: 2rpx solid #FF6B8B;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.time-input-value {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  background-color: #ffffff;
  border: 2rpx solid #FF6B8B;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 原生picker组件的样式 */
.time-picker-native {
  display: block;
  width: 100%;
  position: relative;
  z-index: 1;
}

/* 地点输入 */
.location-input {
  display: flex;
  gap: 10rpx;
  align-items: center;
}

.location-input .form-input {
  flex: 1;
}

.location-btn {
  width: 120rpx;
  height: 80rpx;
  background-color: #FF6B8B;
  color: #ffffff;
  font-size: 26rpx;
  border-radius: 10rpx;
  border: none;
  line-height: 80rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 人数控制 - 一行两个设置项 */
.people-count {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 一行两个设置项 */
.count-row-inline {
  display: flex;
  align-items: center;
  background-color: #f9f9f9;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  padding: 24rpx 16rpx;
}

.count-inline {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.count-inline-label {
  font-size: 26rpx;
  color: #888888;
  font-weight: 500;
  min-width: 50rpx;
}

.count-inline-control {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.count-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #e0e0e0;
  margin: 0 16rpx;
}

/* 小号步进器按钮 */
.stepper-btn-small {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 139, 0.25);
}

.stepper-btn-small:active {
  transform: scale(0.92);
  opacity: 0.9;
}

.stepper-btn-small.disabled {
  background: linear-gradient(135deg, #e8e8e8 0%, #f0f0f0 100%);
  box-shadow: none;
}

.stepper-btn-small.disabled:active {
  transform: none;
  opacity: 1;
}

.stepper-btn-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffffff;
  line-height: 1;
}

.stepper-btn-small.disabled .stepper-btn-text {
  color: #bbbbbb;
}

.stepper-num {
  min-width: 44rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B8B;
  text-align: center;
}

/* 进度条 */
.people-progress {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.progress-bar {
  width: 100%;
  height: 14rpx;
  background-color: #f0f0f0;
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B8B 0%, #FF8E53 100%);
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #FF6B8B;
  text-align: center;
  font-weight: 500;
}

/* 活动图片上传样式 */
.image-upload {
  display: flex;
  margin-top: 20rpx;
}

.image-preview {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #e0e0e0;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.image-preview image {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f8f8;
}

.image-placeholder-text {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  padding: 0 20rpx;
}

/* 标签选择 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.tag-item {
  padding: 16rpx 28rpx;
  background-color: #f8f8f8;
  color: #666666;
  font-size: 28rpx;
  border-radius: 50rpx;
  border: 2rpx solid #e8e8e8;
  box-sizing: border-box;
  cursor: pointer;
  transition: all 0.2s ease;
}

.tag-item.selected {
  background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%);
  color: #ffffff;
  border: 2rpx solid #FF6B8B;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 139, 0.25);
}

/* 价格提示 */
.price-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.price-input {
  flex: 1;
}

.price-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  white-space: nowrap;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  height: 180rpx;
  background-color: #f8f8f8;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
  border: 1rpx solid #e0e0e0;
  box-sizing: border-box;
  resize: none;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B8B 0%, #FF8E53 100%);
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  line-height: 96rpx;
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 139, 0.35);
  color: #ffffff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.submit-btn:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 139, 0.45);
}

.submit-btn:disabled {
  background: linear-gradient(135deg, #ffb3c1 0%, #ffc5d0 100%);
  color: rgba(255, 255, 255, 0.7);
  box-shadow: none;
}

.submit-btn text {
  color: #ffffff;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 活动规则 */
.rule-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.rule-label {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.rule-switch {
  transform: scale(0.8);
}

.deposit-rules {
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 10rpx;
  margin-top: 20rpx;
}

.small-input {
  width: 200rpx;
  flex: none;
}